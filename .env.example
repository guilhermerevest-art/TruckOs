# =====================================================================
# TruckOS — Environment variables (TEMPLATE)
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local.
# NUNCA coloque chaves reais neste arquivo.
# =====================================================================

# ---------- Supabase ----------
# Projeto: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...      # chave anon (pública, vai pro client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # service_role (SECRETA, só server-side)

# ---------- Stripe (opcional em F1 — preencher depois) ----------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# URL pública do app (usada nos retornos do Stripe Checkout)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Anthropic (Claude) — Helpers de IA ----------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---------- Evolution API (WhatsApp) — opcional no F1 ----------
EVOLUTION_API_URL=
EVOLUTION_API_GLOBAL_KEY=
EVOLUTION_WEBHOOK_SECRET=

# ---------- Sentry (opcional) ----------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=